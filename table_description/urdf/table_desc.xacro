<?xml version="1.0"?>
<robot name="table_desc" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================= PROPERTIES ================= -->
  <xacro:property name="table_length" value="1.0"/>
  <xacro:property name="table_width"  value="0.5"/>
  <xacro:property name="table_thickness" value="0.05"/>

  <xacro:property name="leg_size" value="0.05"/>
  <xacro:property name="leg_height" value="1.0"/>

  <xacro:property name="table_mass" value="50"/>
  <xacro:property name="leg_mass" value="10"/>

  <!-- ================= MATERIALS ================= -->
  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>

  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>

  <!-- ================= TABLE TOP ================= -->
  <link name="table_sup">
    <visual>
      <geometry>
        <box size="${table_length} ${table_width} ${table_thickness}"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <collision>
      <geometry>
        <box size="${table_length} ${table_width} ${table_thickness}"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${table_mass}"/>
      <inertia ixx="1e-3" ixy="0.0" ixz="0.0"
               iyy="1e-3" iyz="0.0" izz="1e-3"/>
    </inertial>
  </link>

  <!-- ================= LEG MACRO ================= -->
  <xacro:macro name="table_leg" params="name x y">

    <link name="${name}">
      <visual>
        <origin xyz="0 0 -${leg_height/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${leg_size} ${leg_size} ${leg_height}"/>
        </geometry>
        <material name="black"/>
      </visual>

      <collision>
        <origin xyz="0 0 -${leg_height/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${leg_size} ${leg_size} ${leg_height}"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 -${leg_height/2}" rpy="0 0 0"/>
        <mass value="${leg_mass}"/>
        <inertia ixx="1e-3" ixy="0.0" ixz="0.0"
                 iyy="1e-3" iyz="0.0" izz="1e-3"/>
      </inertial>
    </link>

    <joint name="table_to_${name}" type="fixed">
      <parent link="table_sup"/>
      <child link="${name}"/>
      <origin xyz="${x} ${y} 0" rpy="0 0 0"/>
    </joint>

  </xacro:macro>

  <!-- ================= CREATE 4 LEGS ================= -->
  <xacro:table_leg name="leg_1" x="-${table_length/2}" y="-${table_width/2}"/>
  <xacro:table_leg name="leg_2" x="${table_length/2}"  y="-${table_width/2}"/>
  <xacro:table_leg name="leg_3" x="${table_length/2}"  y="${table_width/2}"/>
  <xacro:table_leg name="leg_4" x="-${table_length/2}" y="${table_width/2}"/>

</robot>