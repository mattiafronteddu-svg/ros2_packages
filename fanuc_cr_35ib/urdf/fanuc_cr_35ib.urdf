        <!-- <inertial>
            <mass value=""/>
            <origin rpy="" xyz=""/>
            <inertia ixx="" ixy="" ixz="" iyy="" iyz="" izz=""/>
        </inertial> -->
    </link>

<!-- Joint 6 and Link 6 -->

    <joint name="J6" type="revolute">
        <origin rpy="-1.570796 0 0" xyz="0 0 0"/>
        <parent link="link5"/>
        <child link="link6"/>
        <axis xyz="0 0 1"/>
        <limit lower="-7.85" upper="7.85" effort="1" velocity="1.0"/>
    </joint>
    <link name="link6">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/link6.stl" scale="0.001 0.001 0.001"/>
            </geometry>
