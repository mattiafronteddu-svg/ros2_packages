        <!-- <inertial>
            <mass value=""/>
            <origin rpy="" xyz=""/>
            <inertia ixx="" ixy="" ixz="" iyy="" iyz="" izz=""/>
        </inertial> -->
    </link>

    <joint name="cover_j3" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <parent link="link3"/>
        <child link="cover_j3"/>
    </joint>
    <link name="cover_j3">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/coverj3.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="green"/>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/coverj3.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <!-- <inertial>
            <mass value=""/>
            <origin rpy="" xyz=""/>
            <inertia ixx="" ixy="" ixz="" iyy="" iyz="" izz=""/>
        </inertial> -->
    </link>

<!-- Joint 4 and Link 4 -->

    <joint name="J4" type="revolute">
        <origin rpy="-1.570796 0 0" xyz="0.215 0 0"/>
        <parent link="link3"/>
        <child link="link4"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.49" upper="3.49" effort="1" velocity="1.0"/>
    </joint>
    <link name="link4">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
