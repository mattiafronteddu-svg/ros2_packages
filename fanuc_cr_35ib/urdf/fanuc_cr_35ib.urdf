        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/link6.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <!-- <inertial>
            <mass value=""/>
            <origin rpy="" xyz=""/>
            <inertia ixx="" ixy="" ixz="" iyy="" iyz="" izz=""/>
        </inertial> -->
    </link>

<!-- TCP -->

    <joint name="tcp" type="fixed">
        <origin rpy="3.141593 0 0" xyz="0 0 -0.090"/>
        <parent link="link6"/>
        <child link="tcp"/>
    </joint>
    <link name="tcp"/>

</robot>