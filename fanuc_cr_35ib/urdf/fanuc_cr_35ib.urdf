        </collision>
        <!-- <inertial>
            <mass value=""/>
            <origin rpy="" xyz=""/>
            <inertia ixx="" ixy="" ixz="" iyy="" iyz="" izz=""/>
        </inertial> -->
    </link>

<!-- Joint 5 and Link 5 -->

    <joint name="J5" type="revolute">
        <origin rpy="1.570796 0 0" xyz="0 0 -0.890"/>
        <parent link="link4"/>
        <child link="link5"/>
        <axis xyz="0 0 1"/>
        <limit lower="-2.44" upper="2.44" effort="1" velocity="1.0"/>
    </joint>
    <link name="link5">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
