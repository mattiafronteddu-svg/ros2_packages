        </collision>
        <!-- <inertial>
            <mass value=""/>
            <origin rpy="" xyz=""/>
            <inertia ixx="" ixy="" ixz="" iyy="" iyz="" izz=""/>
        </inertial> -->
    </link>

<!-- Joint 3 and Link 3 -->

    <joint name="J3" type="revolute">
        <origin rpy="3.141529 0 -1.570796" xyz="0 -0.840 0"/>
        <parent link="link2"/>
        <child link="link3"/>
        <axis xyz="0 0 1"/>
        <limit lower="-2.42" upper="3.49" effort="1" velocity="1.0"/>
    </joint>
    <link name="link3">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/link3.stl" scale="0.001 0.001 0.001"/>
