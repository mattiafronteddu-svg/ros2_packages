<?xml version="1.0"?>

<robot name="cr_35ib" xmlns:xacro="http://www.ros.org/wiki/xacro">

 <xacro:macro name="fanuc" params="prefix parent xyz rpy">

    <xacro:arg name="inertia_mode_sim" default="True"/>
    <xacro:if value="$(arg inertia_mode_sim)">
        <xacro:include filename="$(find fanuc_cr_35ib)/urdf/inertias_generated.xacro"/>
    </xacro:if>
    <xacro:unless value="$(arg inertia_mode_sim)">
        <xacro:include filename="$(find fanuc_cr_35ib)/urdf/inertial_parameters_real.xacro"/>
    </xacro:unless>
    <!-- <xacro:inertia_data inertia_mode_sim="$(arg inertia_mode_sim)"/> -->

    <!-- base Joint and Link 0 -->

    <joint name="${prefix}base_joint" type="fixed">
        <origin rpy="${rpy}" xyz="${xyz}"/>
        <parent link="${parent}"/>
        <child link="${prefix}sensor"/>
    </joint>

    <link name="${prefix}sensor">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/sensor.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/sensor.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="${s_mass}"/>
            <origin rpy="${s_rpy}" xyz="${s_xyz}"/>
            <inertia ixx="${s_ixx}" ixy="${s_ixy}" ixz="${s_ixz}" iyy="${s_iyy}" iyz="${s_iyz}" izz="${s_izz}"/>
        </inertial>
    </link>

    <joint name="${prefix}base_joint2" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <parent link="${prefix}sensor"/>
        <child link="${prefix}base"/>
    </joint>

    <link name="${prefix}base">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/base.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/base.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="${b_mass}"/>
            <origin rpy="${b_rpy}" xyz="${b_xyz}"/>
            <inertia ixx="${b_ixx}" ixy="${b_ixy}" ixz="${b_ixz}" iyy="${b_iyy}" iyz="${b_iyz}" izz="${b_izz}"/>
        </inertial>
    </link>

    <!-- Joint 1 and Link 1 -->

    <joint name="${prefix}J1" type="revolute">
        <origin rpy="0 0 0" xyz="0 0 0.668"/>
        <parent link="${prefix}base"/>
        <child link="${prefix}link1"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.23" upper="3.23" effort="1" velocity="1.0"/>
    </joint>
    <link name="${prefix}link1">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/link1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="green"/>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/link1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="${l1_mass}"/>
            <origin rpy="${l1_rpy}" xyz="${l1_xyz}"/>
            <inertia ixx="${l1_ixx}" ixy="${l1_ixy}" ixz="${l1_ixz}" iyy="${l1_iyy}" iyz="${l1_iyz}" izz="${l1_izz}"/>
        </inertial>
    </link>

    <joint name="${prefix}cover_j1" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <parent link="${prefix}link1"/>
        <child link="${prefix}cover_j1"/>
    </joint>
    <link name="${prefix}cover_j1">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/coverj1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="green"/>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/coverj1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="${c1_mass}"/>
            <origin rpy="${c1_rpy}" xyz="${c1_xyz}"/>
            <inertia ixx="${c1_ixx}" ixy="${c1_ixy}" ixz="${c1_ixz}" iyy="${c1_iyy}" iyz="${c1_iyz}" izz="${c1_izz}"/>
        </inertial>
    </link>

    <joint name="${prefix}rear_cover_j1" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <parent link="${prefix}link1"/>
        <child link="${prefix}rear_cover_j1"/>
    </joint>
    <link name="${prefix}rear_cover_j1">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/rearcoverj1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="green"/>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/rearcoverj1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="${rc1_mass}"/>
            <origin rpy="${rc1_rpy}" xyz="${rc1_xyz}"/>
            <inertia ixx="${rc1_ixx}" ixy="${rc1_ixy}" ixz="${rc1_ixz}" iyy="${rc1_iyy}" iyz="${rc1_iyz}" izz="${rc1_izz}"/>
        </inertial>
    </link>

    <!-- Joint 2 and Link 2 -->

    <joint name="${prefix}J2" type="revolute">
        <origin rpy="-1.570796 0 0" xyz="0.075 0 0"/>
        <parent link="${prefix}link1"/>
        <child link="${prefix}link2"/>
        <axis xyz="0 0 1"/>
        <limit lower="-1.40" upper="2.36" effort="1" velocity="1.0"/>
    </joint>
    <link name="${prefix}link2">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/link2.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="green"/>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/link2.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="${l2_mass}"/>
            <origin rpy="${l2_rpy}" xyz="${l2_xyz}"/>
            <inertia ixx="${l2_ixx}" ixy="${l2_ixy}" ixz="${l2_ixz}" iyy="${l2_iyy}" iyz="${l2_iyz}" izz="${l2_izz}"/>
        </inertial>
    </link>

    <!-- Joint 3 and Link 3 -->

    <joint name="${prefix}J3" type="revolute">
        <origin rpy="3.141529 0 -1.570796" xyz="0 -0.840 0"/>
        <parent link="${prefix}link2"/>
        <child link="${prefix}link3"/>
        <axis xyz="0 0 1"/>
        <limit lower="-2.42" upper="3.49" effort="1" velocity="1.0"/>
    </joint>
    <link name="${prefix}link3">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/link3.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="green"/>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/link3.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="${l3_mass}"/>
            <origin rpy="${l3_rpy}" xyz="${l3_xyz}"/>
            <inertia ixx="${l3_ixx}" ixy="${l3_ixy}" ixz="${l3_ixz}" iyy="${l3_iyy}" iyz="${l3_iyz}" izz="${l3_izz}"/>
        </inertial>
    </link>

    <joint name="${prefix}cover_j3" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <parent link="${prefix}link3"/>
        <child link="${prefix}cover_j3"/>
    </joint>
    <link name="${prefix}cover_j3">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/coverj3.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="green"/>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/coverj3.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="${c3_mass}"/>
            <origin rpy="${c3_rpy}" xyz="${c3_xyz}"/>
            <inertia ixx="${c3_ixx}" ixy="${c3_ixy}" ixz="${c3_ixz}" iyy="${c3_iyy}" iyz="${c3_iyz}" izz="${c3_izz}"/>
        </inertial>
    </link>

    <!-- Joint 4 and Link 4 -->

    <joint name="${prefix}J4" type="revolute">
        <origin rpy="-1.570796 0 0" xyz="0.215 0 0"/>
        <parent link="${prefix}link3"/>
        <child link="${prefix}link4"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.49" upper="3.49" effort="1" velocity="1.0"/>
    </joint>
    <link name="${prefix}link4">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/link4.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="green"/>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/link4.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="${l4_mass}"/>
            <origin rpy="${l4_rpy}" xyz="${l4_xyz}"/>
            <inertia ixx="${l4_ixx}" ixy="${l4_ixy}" ixz="${l4_ixz}" iyy="${l4_iyy}" iyz="${l4_iyz}" izz="${l4_izz}"/>
        </inertial>
    </link>

    <!-- Joint 5 and Link 5 -->

    <joint name="${prefix}J5" type="revolute">
        <origin rpy="1.570796 0 0" xyz="0 0 -0.890"/>
        <parent link="${prefix}link4"/>
        <child link="${prefix}link5"/>
        <axis xyz="0 0 1"/>
        <limit lower="-2.44" upper="2.44" effort="1" velocity="1.0"/>
    </joint>
    <link name="${prefix}link5">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/link5.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="green"/>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/link5.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="${l5_mass}"/>
            <origin rpy="${l5_rpy}" xyz="${l5_xyz}"/>
            <inertia ixx="${l5_ixx}" ixy="${l5_ixy}" ixz="${l5_ixz}" iyy="${l5_iyy}" iyz="${l5_iyz}" izz="${l5_izz}"/>
        </inertial>
    </link>

    <!-- Joint 6 and Link 6 -->

    <joint name="${prefix}J6" type="revolute">
        <origin rpy="-1.570796 0 0" xyz="0 0 0"/>
        <parent link="${prefix}link5"/>
        <child link="${prefix}link6"/>
        <axis xyz="0 0 1"/>
        <limit lower="-7.85" upper="7.85" effort="1" velocity="1.0"/>
    </joint>
    <link name="${prefix}link6">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/link6.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/link6.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="${l6_mass}"/>
            <origin rpy="${l6_rpy}" xyz="${l6_xyz}"/>
            <inertia ixx="${l6_ixx}" ixy="${l6_ixy}" ixz="${l6_ixz}" iyy="${l6_iyy}" iyz="${l6_iyz}" izz="${l6_izz}"/>
        </inertial>
    </link>

    <!-- TCP -->

    <joint name="${prefix}tcp" type="fixed">
        <origin rpy="3.141593 0 0" xyz="0 0 -0.090"/>
        <parent link="${prefix}link6"/>
        <child link="${prefix}tcp"/>
    </joint>
    <link name="${prefix}tcp"/>

    <link name="${prefix}tool_changer_cobot_side">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/tool_changer_cobot_side.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="avorio"/>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://fanuc_cr_35ib/meshes/tool_changer_cobot_side.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
    </link>

    <joint name="${prefix}tc_to_t" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 -0.0925"/>
        <parent link="${prefix}link6"/>
        <child link="${prefix}tool_changer_cobot_side"/>
    </joint>
    
 </xacro:macro>
</robot>