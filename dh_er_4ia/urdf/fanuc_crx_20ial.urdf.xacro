<?xml version="1.0"?>

<robot name="er_4ia" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="$(find dh_er_4ia)/urdf/dh_crx_20ial.xacro"/>

    <link name="world"/>

<!-- Joint1 & Link1 -->

    <joint name="joint1" type="revolute">
        <parent link="world"/>
        <child link="link1"/>
        <origin xyz="${J1_xyz}" rpy="${J1_rpy}"/>
        <axis xyz="0 0 1"/>
        <limit lower="${J1_ll}" upper="${J1_ul}" effort="${J1_e}" velocity="${J1_vl}"/>
    </joint>

    <link name="link1">
        <inertial>
            <mass value="${L1_mass}"/>
            <origin rpy="0.0 0.0 0.0" xyz="${L1_x_com} ${L1_y_com} ${L1_z_com}"/>
            <inertia ixx="${L1_xx}" ixy="0.00" ixz="0.00" iyy="${L1_yy}" iyz="0.00" izz="${L1_zz}"/>
        </inertial>
    </link>

<!-- Joint2 & Link2 -->

    <joint name="joint2" type="revolute">
        <parent link="link1"/>
        <child link="link2"/>
        <origin xyz="${J2_xyz}" rpy="${J2_rpy}"/>
        <axis xyz="0 0 1"/>
        <limit lower="${J2_ll}" upper="${J2_ul}" effort="${J2_e}" velocity="${J2_vl}"/>
    </joint>

    <link name="link2">
        <inertial>
            <mass value="${L2_mass}"/>
            <origin rpy="0.0 0.0 0.0" xyz="${L2_x_com} ${L2_y_com} ${L2_z_com}"/>
            <inertia ixx="${L2_xx}" ixy="0.00" ixz="0.00" iyy="${L2_yy}" iyz="0.00" izz="${L2_zz}"/>
        </inertial>
    </link>

<!-- Joint3 & Link3 -->

    <joint name="joint3" type="revolute">
        <parent link="link2"/>
        <child link="link3"/>
        <origin xyz="${J3_xyz}" rpy="${J3_rpy}"/>
        <axis xyz="0 0 1"/>
        <limit lower="${J3_ll}" upper="${J3_ul}" effort="${J3_e}" velocity="${J3_vl}"/>
    </joint>

    <link name="link3">
        <inertial>
            <mass value="${L3_mass}"/>
            <origin rpy="0.00 0.00 0.00" xyz="${L3_x_com} ${L3_y_com} ${L3_z_com}"/>
            <inertia ixx="${L3_xx}" ixy="0.00" ixz="0.00" iyy="${L3_yy}" iyz="0.00" izz="${L3_zz}"/>
        </inertial>
    </link>

<!-- Joint4 & Link4 -->

    <joint name="joint4" type="revolute">
        <parent link="link3"/>
        <child link="link4"/>
        <origin xyz="${J4_xyz}" rpy="${J4_rpy}"/>
        <axis xyz="0 0 1"/>
        <limit lower="${J4_ll}" upper="${J4_ul}" effort="${J4_e}" velocity="${J4_vl}"/>
    </joint>

    <link name="link4">
        <inertial>
            <mass value="${L4_mass}"/>
            <origin rpy="0.00 0.00 0.00" xyz="${L4_x_com} ${L4_y_com} ${L4_z_com}"/>
            <inertia ixx="${L4_xx}" ixy="0.00" ixz="0.00" iyy="${L4_yy}" iyz="0.00" izz="${L4_zz}"/>
        </inertial>
    </link>

<!-- Joint5 & Link5 -->

    <joint name="joint5" type="revolute">
        <parent link="link4"/>
        <child link="link5"/>
        <origin xyz="${J5_xyz}" rpy="${J5_rpy}"/>
        <axis xyz="0 0 1"/>
        <limit lower="${J5_ll}" upper="${J5_ul}" effort="${J5_e}" velocity="${J5_vl}"/>
    </joint>

    <link name="link5">
        <inertial>
            <mass value="${L5_mass}"/>
            <origin rpy="0.00 0.00 0.00" xyz="${L5_x_com} ${L5_y_com} ${L5_z_com}"/>
            <inertia ixx="${L5_xx}" ixy="0.00" ixz="0.00" iyy="${L5_yy}" iyz="0.00" izz="${L5_zz}"/>
        </inertial>
    </link>

<!-- Joint6 & Link6 -->

    <joint name="joint6" type="revolute">
        <parent link="link5"/>
        <child link="link6"/>
        <origin xyz="${J6_xyz}" rpy="${J6_rpy}"/>
        <axis xyz="0 0 1"/>
        <limit lower="${J6_ll}" upper="${J6_ul}" effort="${J6_e}" velocity="${J6_vl}"/>
    </joint>

    <link name="link6"/>

<!-- TCP -->

    <!-- <joint name="tool_center_point" type="fixed">
        <parent link="link6"/>
        <child link="TCP"/>
        <origin xyz="${J7_xyz}" rpy="${J7_rpy}"/>
    </joint>

    <link name="TCP"/> -->

</robot>