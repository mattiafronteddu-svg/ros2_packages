<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">

  <xacro:macro name="central_rack_tools" params="parent xyz rpy">

    <link name="lower_part">
      <visual>
        <geometry>
          <mesh filename="package://scene_description/meshes/rack_tools_holder_down.stl" scale="0.001  0.001 0.001"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <material name="light_gray"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://scene_description/meshes/rack_tools_holder_down.stl" scale="0.001  0.001 0.001"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </collision>
    </link>

    <joint name="world_to_lower_part" type="fixed">
      <parent link="${parent}"/>
      <child link="lower_part"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint> 

    <link name="upper_part">
      <visual>
        <geometry>
          <mesh filename="package://scene_description/meshes/rack_tools_holder_upper.stl" scale="0.001  0.001 0.001"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <material name="gray"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://scene_description/meshes/rack_tools_holder_upper.stl" scale="0.001  0.001 0.001"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </collision>
    </link>

    <joint name="world_to_upper_part" type="prismatic">
      <parent link="lower_part"/>
      <child link="upper_part"/>
      <origin xyz="-0.310 0.1046 0.1475" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="0" upper="0.5" effort="1000" velocity="1"/>
    </joint> 

    <link name="tool1_vacuum_gripper_cr">
        <visual>
         <geometry>
            <mesh filename="package://scene_description/meshes/tools/tool1_vacuum_gripper.stl" scale="0.001  0.001 0.001"/>
         </geometry>
         <origin xyz="0 0 0" rpy="0 0 0"/>
         <material name="cornflower_blue"/>
        </visual>
        <collision>
         <geometry>
            <mesh filename="package://scene_description/meshes/tools/tool1_vacuum_gripper.stl" scale="0.001  0.001 0.001"/>
         </geometry>
         <origin xyz="0 0 0" rpy="0 0 0"/>
        </collision>
    </link>

    <joint name="upper_part_to_tool1" type="fixed">
        <parent link="upper_part"/>
        <child link="tool1_vacuum_gripper_cr"/>
        <origin xyz="-0.1265 -0.4677 0.9978" rpy="0 0 0"/>
    </joint> 

    <link name="tool5_detacher">
        <visual>
         <geometry>
             <mesh filename="package://scene_description/meshes/tools/tool5_detacher.stl" scale="0.001  0.001 0.001"/>
         </geometry>
         <origin xyz="0 0 0" rpy="0 0 0"/>
         <material name="cornflower_blue"/>
         </visual>
        <collision>
         <geometry>
            <mesh filename="package://scene_description/meshes/tools/tool5_detacher.stl" scale="0.001  0.001 0.001"/>
         </geometry>
         <origin xyz="0 0 0" rpy="0 0 0"/>
        </collision>
    </link>

    <joint name="upper_part_to_tool5" type="fixed">
        <parent link="upper_part"/>
        <child link="tool5_detacher"/>
        <origin xyz="0.1265 -0.4677 0.9978" rpy="0 0 0"/>
    </joint> 

  </xacro:macro>

</robot>