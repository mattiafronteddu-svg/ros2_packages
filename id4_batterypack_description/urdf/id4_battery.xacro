<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro" name="scene">

  <xacro:include filename="$(find id4_batterypack_description)/urdf/materials.xacro"/>
  <xacro:include filename="$(find id4_batterypack_description)/urdf/module_with_screws.xacro"/>
  <xacro:include filename="$(find id4_batterypack_description)/urdf/busbar_type1.xacro"/>

  <link name="world"/>

  <!-- ================= GLOBAL PARAMETERS ================= -->

  <!-- Module base pose (row A) -->
  <xacro:property name="module_world_x" value="0.0351"/>
  <xacro:property name="module_world_y" value="0.2395"/>
  <xacro:property name="module_world_z" value="0.071"/>
  <xacro:property name="module_pitch"   value="0.249"/>

  <!-- Mirror row (row B): shift in Y 0.202 -->
  <xacro:property name="module_mirror_y" value="0.202"/>

  <!-- BMS base pose -->
  <xacro:property name="bms_world_x" value="-0.003"/>
  <xacro:property name="bms_world_y" value="0.290"/>
  <xacro:property name="bms_world_z" value="0.097"/>
  <xacro:property name="bms_pitch"   value="0.509"/>


  <!-- ================= MACROS ================= -->

  <!-- Generic lens screw (used for BMS + top cover patterns) -->
  <xacro:macro name="screw_lens" params="name parent xyz rpy">
    <link name="${name}">
      <visual>
        <geometry>
          <mesh filename="package://id4_batterypack_description/meshes/lens_flange_m5x25.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <material name="black"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://id4_batterypack_description/meshes/lens_flange_m5x25.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </collision>
    </link>

    <joint name="${name}_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${name}"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>
  </xacro:macro>

  <!-- Screw for BMS (reuse lens screw, fixed rpy=0) -->
  <xacro:macro name="screw_bms" params="name parent xyz">
    <xacro:screw_lens name="${name}" parent="${parent}" xyz="${xyz}" rpy="0 0 0"/>
  </xacro:macro>

  <!-- One BMS instance -->
  <xacro:macro name="bms_instance" params="prefix idx world_x world_y world_z">
    <link name="${prefix}bms_${idx}">
      <visual>
        <geometry>
          <mesh filename="package://id4_batterypack_description/meshes/bms.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <material name="black"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://id4_batterypack_description/meshes/bms.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </collision>
    </link>

    <joint name="world_to_${prefix}bms_${idx}" type="fixed">
      <parent link="world"/>
      <child link="${prefix}bms_${idx}"/>
      <origin xyz="${world_x} ${world_y} ${world_z}" rpy="0 0 0"/>
    </joint>

    <xacro:screw_bms name="${prefix}bms_${idx}_s1" parent="${prefix}bms_${idx}" xyz="0 0 0.01"/>
    <xacro:screw_bms name="${prefix}bms_${idx}_s2" parent="${prefix}bms_${idx}" xyz="0 0.334 0.01"/>
  </xacro:macro>

  <!-- ================= PATTERN MACROS ================= -->

  <!-- Row along X: i = 0..n-1 at (x0 + i*dx, y0, z0) -->
  <xacro:macro name="screw_row_x_rec" params="prefix parent i n x0 y0 z0 dx rpy">
    <xacro:if value="${i &lt; n}">
      <xacro:screw_lens name="${prefix}${i}" parent="${parent}"
                        xyz="${x0 + i*dx} ${y0} ${z0}" rpy="${rpy}"/>
      <xacro:screw_row_x_rec prefix="${prefix}" parent="${parent}"
                             i="${i + 1}" n="${n}"
                             x0="${x0}" y0="${y0}" z0="${z0}" dx="${dx}" rpy="${rpy}"/>
    </xacro:if>
  </xacro:macro>

  <xacro:macro name="screw_row_x" params="prefix parent n x0 y0 z0 dx rpy">
    <xacro:screw_row_x_rec prefix="${prefix}" parent="${parent}"
                           i="0" n="${n}" x0="${x0}" y0="${y0}" z0="${z0}" dx="${dx}" rpy="${rpy}"/>
  </xacro:macro>

  <!-- Column along Y: i = 0..n-1 at (x0, y0 + i*dy, z0) -->
  <xacro:macro name="screw_col_y_rec" params="prefix parent i n x0 y0 z0 dy rpy">
    <xacro:if value="${i &lt; n}">
      <xacro:screw_lens name="${prefix}${i}" parent="${parent}"
                        xyz="${x0} ${y0 + i*dy} ${z0}" rpy="${rpy}"/>
      <xacro:screw_col_y_rec prefix="${prefix}" parent="${parent}"
                             i="${i + 1}" n="${n}"
                             x0="${x0}" y0="${y0}" z0="${z0}" dy="${dy}" rpy="${rpy}"/>
    </xacro:if>
  </xacro:macro>

  <xacro:macro name="screw_col_y" params="prefix parent n x0 y0 z0 dy rpy">
    <xacro:screw_col_y_rec prefix="${prefix}" parent="${parent}"
                           i="0" n="${n}" x0="${x0}" y0="${y0}" z0="${z0}" dy="${dy}" rpy="${rpy}"/>
  </xacro:macro>

  <!-- ================= INSTANCES ================= -->
  <xacro:busbar_1_with_screws
    name="busbar1_0"
    parent="world"
    xyz="0.0341 0.216 0.4"
    rpy="0 0 0"/>

  <xacro:busbar_1_with_screws
    name="busbar1_1"
    parent="world"
    xyz="0.0341 ${0.216+0.249} 0.4"
    rpy="0 0 0"/>

  <xacro:busbar_1_with_screws
    name="busbar1_2"
    parent="world"
    xyz="0.0341 ${0.216+2*0.249} 0.4"
    rpy="0 0 0"/>
    
  <xacro:busbar_1_with_screws
    name="busbar1_3"
    parent="world"
    xyz="0.0341 ${0.216+3*0.249+0.269} 0.4"
    rpy="0 0 0"/>

  <xacro:busbar_1_with_screws
    name="busbar1_4"
    parent="world"
    xyz="0.0341 ${0.216+3*0.249+0.269*2+0.249} 0.4"
    rpy="0 0 0"/>

  <xacro:busbar_1_with_screws
    name="busbar1_5"
    parent="world"
    xyz="0.0341 ${0.216+3*0.249+0.269*2+0.249*2} 0.4"
    rpy="0 0 0"/>

  <!-- 6 modules - row A -->
  <xacro:module_instance prefix="" idx="0"
    world_x="${ module_world_x }"
    world_y="${ module_world_y + 0*module_pitch }"
    world_z="${ module_world_z }"
    world_rpy="0 0 0"/>
  <xacro:module_instance prefix="" idx="1"
    world_x="${ module_world_x }"
    world_y="${ module_world_y + 1*module_pitch }"
    world_z="${ module_world_z }"
    world_rpy="0 0 0"/>
  <xacro:module_instance prefix="" idx="2"
    world_x="${ module_world_x }"
    world_y="${ module_world_y + 2*module_pitch }"
    world_z="${ module_world_z }"
    world_rpy="0 0 0"/>
  <xacro:module_instance prefix="" idx="3"
    world_x="${ module_world_x }"
    world_y="${ module_world_y + 3*module_pitch }"
    world_z="${ module_world_z }"
    world_rpy="0 0 0"/>
  <xacro:module_instance prefix="" idx="4"
    world_x="${ module_world_x }"
    world_y="${ module_world_y + 4*module_pitch }"
    world_z="${ module_world_z }"
    world_rpy="0 0 0"/>
  <xacro:module_instance prefix="" idx="5"
    world_x="${ module_world_x }"
    world_y="${ module_world_y + 5*module_pitch }"
    world_z="${ module_world_z }"
    world_rpy="0 0 0"/>

  <!-- 6 modules - row B (mirrored): x flipped, yaw=pi (xacro provides ${pi}), y shifted -->
  <xacro:module_instance prefix="mir_" idx="0"
    world_x="${ -module_world_x }"
    world_y="${ module_world_y + module_mirror_y + 0*module_pitch }"
    world_z="${ module_world_z }"
    world_rpy="0 0 ${pi}"/>
  <xacro:module_instance prefix="mir_" idx="1"
    world_x="${ -module_world_x }"
    world_y="${ module_world_y + module_mirror_y + 1*module_pitch }"
    world_z="${ module_world_z }"
    world_rpy="0 0 ${pi}"/>
  <xacro:module_instance prefix="mir_" idx="2"
    world_x="${ -module_world_x }"
    world_y="${ module_world_y + module_mirror_y + 2*module_pitch }"
    world_z="${ module_world_z }"
    world_rpy="0 0 ${pi}"/>
  <xacro:module_instance prefix="mir_" idx="3"
    world_x="${ -module_world_x }"
    world_y="${ module_world_y + module_mirror_y + 3*module_pitch }"
    world_z="${ module_world_z }"
    world_rpy="0 0 ${pi}"/>
  <xacro:module_instance prefix="mir_" idx="4"
    world_x="${ -module_world_x }"
    world_y="${ module_world_y + module_mirror_y + 4*module_pitch }"
    world_z="${ module_world_z }"
    world_rpy="0 0 ${pi}"/>
  <xacro:module_instance prefix="mir_" idx="5"
    world_x="${ -module_world_x }"
    world_y="${ module_world_y + module_mirror_y + 5*module_pitch }"
    world_z="${ module_world_z }"
    world_rpy="0 0 ${pi}"/>

  <!-- 3 BMS -->
  <xacro:bms_instance prefix="" idx="0"
    world_x="${ bms_world_x }"
    world_y="${ bms_world_y + 0*bms_pitch }"
    world_z="${ bms_world_z }"/>
  <xacro:bms_instance prefix="" idx="1"
    world_x="${ bms_world_x }"
    world_y="${ bms_world_y + 1*bms_pitch }"
    world_z="${ bms_world_z }"/>
  <xacro:bms_instance prefix="" idx="2"
    world_x="${ bms_world_x }"
    world_y="${ bms_world_y + 2*bms_pitch }"
    world_z="${ bms_world_z }"/>

  <!-- ===== Top cover screws pattern 1: 18 along -X, plus a single copy in +Y (1.8m) ===== -->
  <xacro:screw_row_x prefix="row0_screw_" parent="world"
    n="18" x0="0.595" y0="0.074" z0="0.25" dx="-0.070" rpy="0 0 0"/>

  <xacro:screw_row_x prefix="row1_screw_" parent="world"
    n="18" x0="0.595" y0="${0.074 + 1.8}" z0="0.25" dx="-0.070" rpy="0 0 0"/>

  <!-- ===== Top cover screws pattern 2: 27 along +Y, plus a single mirrored copy in -X by (-0.637*2) ===== -->
  <xacro:screw_col_y prefix="col0_" parent="world"
    n="23" x0="0.637" y0="0.1345" z0="0.25" dy="0.070" rpy="0 0 0"/>

  <xacro:screw_col_y prefix="col1_" parent="world"
    n="23" x0="${0.637 + (-0.637*2)}" y0="0.1345" z0="0.25" dy="0.070" rpy="0 0 0"/>


   <link name="busbar_type3">
      <visual>
        <geometry>
          <mesh filename="package://id4_batterypack_description/meshes/busbar_3.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <material name="orange"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://id4_batterypack_description/meshes/busbar_3.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </collision>
    </link>

    <joint name="world_to_busbar_3" type="fixed">
      <parent link="world"/>
      <child link="busbar_type3"/>
      <origin xyz="0 1.7005 0.4" rpy="0 0 ${pi}"/>
    </joint>
</robot>